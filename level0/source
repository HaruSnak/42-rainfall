#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>

void main(int argc, char **argv) {
	if (atoi(argv[1]) == 423) {
		gid_t gid = getegid();
		uid_t uid = geteuid();

		setresgid(gid, gid, gid);
		setresuid(uid, uid, uid);
		execl("/bin/sh", "sh", NULL);
	}
	else
		return (0);
	return (0);
}
